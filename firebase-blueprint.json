{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["superadmin", "member"]
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["email", "role"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "logoUrl": {
          "type": "string"
        }
      },
      "required": ["name", "description", "logoUrl"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles and roles"
    },
    "/settings/app": {
      "schema": {
        "$ref": "#/entities/AppSettings"
      },
      "description": "App branding settings"
    }
  }
}
